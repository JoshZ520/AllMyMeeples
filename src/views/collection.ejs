<section id="collection" class="section">
  <div class="section-header">
    <h2>My Collection</h2>
    <p>Games on your shelf that are ready to play</p>
  </div>
  
  <div id="collection-status" class="collection-status" style="display: none;">
    <p id="status-message"></p>
  </div>

  <div id="shelf-games" class="card-grid">
    <!-- Populated by JavaScript -->
  </div>

  <div id="empty-shelf" class="empty-state" style="display: none; text-align: center; padding: 3rem 1rem;">
    <p>No games on your shelf yet.</p>
    <p><a href="/" class="button primary">Browse all games</a></p>
  </div>
</section>

<script>
  // Fetch and display shelf games
  async function loadShelf() {
    try {
      const response = await fetch('/api/shelf');
      const games = await response.json();
      const container = document.getElementById('shelf-games');
      const emptyState = document.getElementById('empty-shelf');

      if (games.length === 0) {
        container.style.display = 'none';
        emptyState.style.display = 'block';
        return;
      }

      container.innerHTML = games.map(game => `
        <article class="card">
          <img src="${game.image_url}" alt="${game.title}" style="width: 100%; height: 200px; object-fit: cover; border-radius: 4px; margin-bottom: 1rem;">
          <h3>${game.title}</h3>
          <p style="color: var(--muted); font-size: 0.9rem; margin: 0.5rem 0;">
            ${game.min_players}-${game.max_players} players | ${game.playtime_minutes} min
          </p>
          <p>${game.description || 'A great game to play.'}</p>
          <p><strong>Rating:</strong> ⭐ ${game.rating || 'N/A'}</p>
          <button class="button primary" onclick="removeFromShelf(${game.id})" style="width: 100%; margin-top: 1rem;">
            Remove from Shelf
          </button>
        </article>
      `).join('');
    } catch (error) {
      console.error('Error loading shelf:', error);
    }
  }

  async function removeFromShelf(gameId) {
    try {
      const response = await fetch(`/api/games/${gameId}/shelf`, {
        method: 'DELETE'
      });

      if (response.ok) {
        showStatus('Game removed from shelf!', 'success');
        loadShelf();
      } else {
        showStatus('Failed to remove game', 'error');
      }
    } catch (error) {
      console.error('Error removing from shelf:', error);
      showStatus('Error removing game', 'error');
    }
  }

  function showStatus(message, type) {
    const status = document.getElementById('collection-status');
    const statusMessage = document.getElementById('status-message');
    statusMessage.textContent = message;
    status.className = `collection-status ${type}`;
    status.style.display = 'block';
    setTimeout(() => {
      status.style.display = 'none';
    }, 3000);
  }

  // Load shelf when page loads
  loadShelf();
</script>

<style>
  .collection-status {
    padding: 1rem;
    border-radius: 4px;
    margin-bottom: 1.5rem;
    font-weight: 500;
  }

  .collection-status.success {
    background: #d4edda;
    color: #155724;
    border: 1px solid #c3e6cb;
  }

  .collection-status.error {
    background: #f8d7da;
    color: #721c24;
    border: 1px solid #f5c6cb;
  }

  .empty-state {
    background: var(--card);
    border: 2px dashed var(--border);
    border-radius: 8px;
  }
</style>
