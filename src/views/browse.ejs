<section class="section">
  <div class="browse-hero">
    <div class="browse-hero-content">
      <p class="eyebrow">Tabletop collection tracker</p>
      <h1>Browse games</h1>
      <p>Track your collection, plan your wishlist, and get game night ready.</p>
      <div class="browse-hero-actions">
        <% if (user) { %>
          <a href="/collection" class="button primary">View my collection</a>
        <% } else { %>
          <a href="/auth/register" class="button primary">Create account</a>
          <a href="/auth/login" class="button secondary">Log in</a>
        <% } %>
      </div>
    </div>
    <div class="browse-hero-card">
      <h2>Ready to build your shelf?</h2>
      <p>Pick a few favorites and start tracking plays.</p>
    </div>
  </div>

  <div class="section-header">
    <h2>Browse All Games</h2>
    <p>Pick multiple games and add them to your shelf in one go.</p>
  </div>

  <div class="browse-summary">
    <div class="summary-card">
      <p class="summary-label">Your collection</p>
      <p id="collection-count" class="summary-value">--</p>
    </div>
    <div id="login-hint" class="summary-card summary-muted" style="display: none;">
      Log in to see your collection count and owned games.
    </div>
  </div>

  <div class="browse-filters">
    <div class="filter-group">
      <label for="search-games">Search</label>
      <input type="search" id="search-games" name="search" placeholder="Search by title or description" />
    </div>
    <div class="filter-group">
      <label for="filter-players">Players</label>
      <select id="filter-players" name="players">
        <option value="">Any</option>
        <option value="1">1+</option>
        <option value="2">2+</option>
        <option value="3">3+</option>
        <option value="4">4+</option>
        <option value="5">5+</option>
        <option value="6">6+</option>
      </select>
    </div>
    <div class="filter-group">
      <label for="filter-playtime">Playtime</label>
      <select id="filter-playtime" name="playtime">
        <option value="">Any</option>
        <option value="30">Up to 30 min</option>
        <option value="45">Up to 45 min</option>
        <option value="60">Up to 60 min</option>
        <option value="90">Up to 90 min</option>
        <option value="120">Up to 120 min</option>
      </select>
    </div>
    <div class="filter-group">
  <label for="sort-by">Sort</label>
  <select id="sort-by" name="sort">
    <option value="title-asc">Title (A-Z)</option>
    <option value="title-desc">Title (Z-A)</option>
    <option value="rating-desc">Rating (high → low)</option>
    <option value="playtime-asc">Playtime (short → long)</option>
    <option value="playtime-desc">Playtime (long → short)</option>
  </select>
</div>
  </div>

  <div id="bulk-actions" class="bulk-actions" style="display: none;">
    <span><strong id="selected-count">0</strong> selected</span>
    <button id="bulk-add" class="button primary">Add selected to shelf</button>
  </div>

  <div id="games-container" class="card-grid">
    <p class="card-grid-loading">Loading games...</p>
  </div>
</section>

<script src="/js/browse.js"></script>
