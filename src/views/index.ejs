<section class="hero">
  <div class="hero-content">
    <p class="eyebrow">Tabletop collection tracker</p>
    <h1><%= title %></h1>
    <p>Track your collection, plan your wishlist, and get game night ready.</p>
    <div class="hero-actions">
      <a href="/browse" class="button primary">Browse games</a>
      <a href="/auth/register" class="button secondary">Create account</a>
    </div>
    <div class="hero-carousel">
      <div class="carousel" data-carousel>
        <div class="carousel-track">
          <div class="carousel-slide is-active">
            <div class="carousel-panel panel-one">
              <p class="eyebrow">Tabletop collection tracker</p>
              <h2>Build your shelf</h2>
              <p>Curate favorites and keep your collection tidy.</p>
            </div>
          </div>
          <div class="carousel-slide">
            <div class="carousel-panel panel-two">
              <p class="eyebrow">Plan ahead</p>
              <h2>Save your wishlist</h2>
              <p>Keep the next big box on deck for game night.</p>
            </div>
          </div>
          <div class="carousel-slide">
            <div class="carousel-panel panel-three">
              <p class="eyebrow">Game night ready</p>
              <h2>Pick the vibe</h2>
              <p>Match the table to your crew and time.</p>
            </div>
          </div>
        </div>

        <button class="carousel-control prev" type="button" aria-label="Previous slide" data-carousel-prev>
          ‹
        </button>
        <button class="carousel-control next" type="button" aria-label="Next slide" data-carousel-next>
          ›
        </button>

        <div class="carousel-dots" role="tablist">
          <button type="button" class="carousel-dot is-active" aria-label="Slide 1" data-carousel-dot="0"></button>
          <button type="button" class="carousel-dot" aria-label="Slide 2" data-carousel-dot="1"></button>
          <button type="button" class="carousel-dot" aria-label="Slide 3" data-carousel-dot="2"></button>
        </div>
      </div>
    </div>
  </div>
</section>


<section id="how-it-works" class="section">
    <div class="section-header">
    <h2>How it works</h2>
    <p>Three quick steps to build your game night flow.</p>
  </div>

  <div class="card-row">
    <div class="flip-card">
      <div class="flip-card-inner">
        <div class="flip-card-front">
          <h3>Browse</h3>
          <p>Find the games you want to play.</p>
        </div>
        <div class="flip-card-back">
          <p>Filter by players, time, and ratings.</p>
        </div>
      </div>
    </div>

    <div class="flip-card">
      <div class="flip-card-inner">
        <div class="flip-card-front">
          <h3>Save</h3>
          <p>Add favorites to your shelf.</p>
        </div>
        <div class="flip-card-back">
          <p>Keep a wishlist for future nights.</p>
        </div>
      </div>
    </div>

    <div class="flip-card">
      <div class="flip-card-inner">
        <div class="flip-card-front">
          <h3>Play</h3>
          <p>Plan sessions with your group.</p>
        </div>
        <div class="flip-card-back">
          <p>Track what you played and loved.</p>
        </div>
      </div>
    </div>
  </div>
</section>
<% if (user) { %> 
<section id="wishlist" class="section">
  <div class="section-header">
    <h2>Wishlist planning</h2>
    <p>Keep the next big box on your radar without the clutter.</p>
  </div>
  <div class="note">
    <p>Add notes like "holiday gift" or "must play at meetup".</p>
  </div>
</section>

<section id="events" class="section">
  <div class="section-header">
    <h2>Game night events</h2>
    <p>Schedule sessions, assign hosts, and keep the vibe cozy.</p>
  </div>
  <div class="timeline">
    <div class="timeline-item">
      <span class="tag">Fri</span>
      <div>
        <h3>First play</h3>
        <p>Short rules teach + warm-up game.</p>
      </div>
    </div>
    <div class="timeline-item">
      <span class="tag">Sat</span>
      <div>
        <h3>Main event</h3>
        <p>Pick a longer campaign or big box adventure.</p>
      </div>
    </div>
  </div>
  <% } %>
</section>

<script src="/js/home.js"></script>
