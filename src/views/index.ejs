<section class="hero">
  <div class="hero-content">
    <p class="eyebrow">Tabletop collection tracker</p>
    <h1><%= title %></h1>
  </div>
  <div class="hero-card">
    <h2>Your Collection</h2>
    <p id="shelf-count" class="shelf-count">0</p>
    <p>games on your shelf</p>
  </div>
</section>

<section id="games" class="section">
  <div class="section-header">
    <h2>Browse All Games</h2>
    <p>Add games to your shelf and plan your game nights</p>
  </div>
  
  <div id="games-container" class="card-grid">
    <p class="card-grid-loading">Loading games...</p>
  </div>
</section>

<section id="wishlist" class="section">
  <div class="section-header">
    <h2>Wishlist planning</h2>
    <p>Keep the next big box on your radar without the clutter.</p>
  </div>
  <div class="note">
    <p>Add notes like "holiday gift" or "must play at meetup".</p>
  </div>
</section>

<section id="events" class="section">
  <div class="section-header">
    <h2>Game night events</h2>
    <p>Schedule sessions, assign hosts, and keep the vibe cozy.</p>
  </div>
  <div class="timeline">
    <div class="timeline-item">
      <span class="tag">Fri</span>
      <div>
        <h3>First play</h3>
        <p>Short rules teach + warm-up game.</p>
      </div>
    </div>
    <div class="timeline-item">
      <span class="tag">Sat</span>
      <div>
        <h3>Main event</h3>
        <p>Pick a longer campaign or big box adventure.</p>
      </div>
    </div>
  </div>
</section>

<script>
  // Load and display games
  async function loadGames() {
    try {
      const response = await fetch('/api/games');
      const games = await response.json();
      const container = document.getElementById('games-container');

      container.innerHTML = games.map(game => `
        <article class="card">
          <img src="${game.image_url}" alt="${game.title}">
          <h3>${game.title}</h3>
          <p class="card-meta">
            ${game.min_players}-${game.max_players} players | ${game.playtime_minutes} min
          </p>
          <p>${game.description || ''}</p>
          <p><strong>Rating:</strong> ⭐ ${game.rating || 'N/A'}</p>
          <button class="button primary add-to-shelf-btn full-width" data-game-id="${game.id}" data-game-title="${game.title}">
            Add to Shelf
          </button>
        </article>
      `).join('');

      // Add event listeners to buttons
      document.querySelectorAll('.add-to-shelf-btn').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          const gameId = btn.dataset.gameId;
          const gameTitle = btn.dataset.gameTitle;
          await addGameToShelf(gameId, btn, gameTitle);
        });
      });

      // Load shelf count
      loadShelfCount();
    } catch (error) {
      console.error('Error loading games:', error);
      document.getElementById('games-container').innerHTML = '<p>Error loading games</p>';
    }
  }

  async function addGameToShelf(gameId, button, gameTitle) {
    try {
      const response = await fetch(`/api/games/${gameId}/shelf`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        }
      });

      if (response.status === 401) {
        // User not logged in - redirect to login
        window.location.href = '/auth/login';
        return;
      }

      if (response.ok) {
        button.textContent = '✓ Added to Shelf';
        button.disabled = true;
        button.style.backgroundColor = 'var(--accent)';
        loadShelfCount();
      } else {
        const error = await response.json();
        alert(error.message || 'This game is already on your shelf');
      }
    } catch (error) {
      console.error('Error adding to shelf:', error);
      alert('Failed to add game to shelf');
    }
  }

  async function loadShelfCount() {
    try {
      const response = await fetch('/api/shelf');
      
      // If not logged in, shelf count is 0
      if (response.status === 401) {
        document.getElementById('shelf-count').textContent = 0;
        return;
      }
      
      const games = await response.json();
      document.getElementById('shelf-count').textContent = games.length;
    } catch (error) {
      console.error('Error loading shelf count:', error);
    }
  }

  // Load games when page loads
  loadGames();
</script>
