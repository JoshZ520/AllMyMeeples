<section class="hero">
  <div class="hero-content">
    <p class="eyebrow">Tabletop collection tracker</p>
    <h1><%= title %></h1>
    <p>Track your collection, plan your wishlist, and get game night ready.</p>
    <div class="hero-actions">
      <a href="/browse" class="button primary">Browse games</a>
      <a href="/auth/register" class="button secondary">Create account</a>
    </div>
  </div>
  <div class="hero-card">
    <h2>Ready to build your shelf?</h2>
    <p>Pick a few favorites and start tracking plays.</p>
  </div>
</section>


<section id="how-it-works" class="section">
    <div class="section-header">
    <h2>How it works</h2>
    <p>Three quick steps to build your game night flow.</p>
  </div>

  <div class="card-row">
    <div class="flip-card">
      <div class="flip-card-inner">
        <div class="flip-card-front">
          <h3>Browse</h3>
          <p>Find the games you want to play.</p>
        </div>
        <div class="flip-card-back">
          <p>Filter by players, time, and ratings.</p>
        </div>
      </div>
    </div>

    <div class="flip-card">
      <div class="flip-card-inner">
        <div class="flip-card-front">
          <h3>Save</h3>
          <p>Add favorites to your shelf.</p>
        </div>
        <div class="flip-card-back">
          <p>Keep a wishlist for future nights.</p>
        </div>
      </div>
    </div>

    <div class="flip-card">
      <div class="flip-card-inner">
        <div class="flip-card-front">
          <h3>Play</h3>
          <p>Plan sessions with your group.</p>
        </div>
        <div class="flip-card-back">
          <p>Track what you played and loved.</p>
        </div>
      </div>
    </div>
  </div>
</section>
<% if (user) { %> 
<section id="wishlist" class="section">
  <div class="section-header">
    <h2>Wishlist planning</h2>
    <p>Keep the next big box on your radar without the clutter.</p>
  </div>
  <div class="note">
    <p>Add notes like "holiday gift" or "must play at meetup".</p>
  </div>
</section>

<section id="events" class="section">
  <div class="section-header">
    <h2>Game night events</h2>
    <p>Schedule sessions, assign hosts, and keep the vibe cozy.</p>
  </div>
  <div class="timeline">
    <div class="timeline-item">
      <span class="tag">Fri</span>
      <div>
        <h3>First play</h3>
        <p>Short rules teach + warm-up game.</p>
      </div>
    </div>
    <div class="timeline-item">
      <span class="tag">Sat</span>
      <div>
        <h3>Main event</h3>
        <p>Pick a longer campaign or big box adventure.</p>
      </div>
    </div>
  </div>
  <% } %>
</section>
